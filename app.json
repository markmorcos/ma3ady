{
  "expo": {
    "name": "ma3ady",
    "slug": "ma3ady",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "ma3ady",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ma3ady",
      "associatedDomains": [
        "applinks:app.ma3ady.com",
        "applinks:preview-app.ma3ady.com"
      ]
    },
    "android": {
      "package": "com.ma3ady",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F766E"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.ma3ady.com"
            },
            {
              "scheme": "https",
              "host": "preview-app.ma3ady.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F766E"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7073f76a-c362-46ea-90ed-928ffaa7a470"
      }
    },
    "owner": "markmorcos"
  }
}