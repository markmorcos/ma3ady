# Public env vars (bundled into the app — no secrets)
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=                # from `supabase status` after `make dev-up`
EXPO_PUBLIC_AUTH_REDIRECT_URI=ma3ady://auth/callback
EXPO_PUBLIC_DEFAULT_LOCALE=en
EXPO_PUBLIC_SHOW_DEV_TOOLS=1
EXPO_PUBLIC_EMAIL_DISPATCHER=mock
EXPO_PUBLIC_WHATSAPP_DISPATCHER=mock
EXPO_PUBLIC_PUSH_DISPATCHER=mock

# Server-side secrets (Supabase Edge Functions, never bundled into the client)
SUPABASE_SERVICE_ROLE_KEY=                    # from `supabase status` locally; from `supabase secrets` in prod
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
RESEND_FROM=Ma3ady <hello@ma3ady.com>
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=event_notification
EMAIL_DISPATCHER=mock
WHATSAPP_DISPATCHER=mock
PUSH_DISPATCHER=mock

# CI / fanout secrets (used by `make secrets-sync-*`)
INFRASTRUCTURE_DISPATCH_TOKEN=
EXPO_TOKEN=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF_PREVIEW=
SUPABASE_PROJECT_REF_PROD=
SUPABASE_DB_PASSWORD_PREVIEW=
SUPABASE_DB_PASSWORD_PROD=
