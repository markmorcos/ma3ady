{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SHOW_DEV_TOOLS": "1",
        "EXPO_PUBLIC_EMAIL_DISPATCHER": "mock",
        "EXPO_PUBLIC_WHATSAPP_DISPATCHER": "mock",
        "EXPO_PUBLIC_PUSH_DISPATCHER": "mock"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SHOW_DEV_TOOLS": "0",
        "EXPO_PUBLIC_EMAIL_DISPATCHER": "mock",
        "EXPO_PUBLIC_WHATSAPP_DISPATCHER": "mock",
        "EXPO_PUBLIC_PUSH_DISPATCHER": "mock",
        "EXPO_PUBLIC_CLIENT_ERROR_SAMPLE_RATE": "1.0"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_SHOW_DEV_TOOLS": "0",
        "EXPO_PUBLIC_EMAIL_DISPATCHER": "real",
        "EXPO_PUBLIC_WHATSAPP_DISPATCHER": "real",
        "EXPO_PUBLIC_PUSH_DISPATCHER": "real",
        "EXPO_PUBLIC_CLIENT_ERROR_SAMPLE_RATE": "0.1"
      },
      "prebuildCommand": "node scripts/assert-real-dispatchers.js"
    }
  },
  "submit": {
    "production": {}
  }
}
